{
  "name": "zyk-mcp",
  "version": "0.1.0",
  "description": "Zyk MCP server — conversational workflow automation via Hatchet",
  "main": "dist/index.js",
  "bin": {
    "zyk-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "setup.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "setup": "node setup.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hatchet-dev/typescript-sdk": "^1.12.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "esbuild": "^0.27.3",
    "tsx": "^4.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
