# Hatchet (required)
HATCHET_CLIENT_TOKEN=your-token-here
HATCHET_HOST_PORT=localhost:7077

# Hatchet gRPC broadcast address.
# Local (default): localhost:7077
# Railway: hatchet-engine.railway.internal:7077
HATCHET_GRPC_BROADCAST_ADDRESS=

# Playground (optional — for running the Next.js playground at localhost:3000)
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
OPENWEATHERMAP_API_KEY=
NEWSAPI_API_KEY=

# Webhook receiver port (default: 3100)
# Trigger workflows via: POST http://localhost:3100/webhook/<workflow_id>
WEBHOOK_PORT=3100

# Analytics (optional — leave blank to disable)
# Set to your PostHog project API key to enable anonymous usage tracking.
# See http://localhost:3100/privacy for what is and isn't collected.
# No PII, no workflow content, no secrets are ever sent.
POSTHOG_KEY=

# Workflow secrets (add what your workflows need)
SLACK_TOKEN=
STRIPE_SECRET_KEY=
GITHUB_TOKEN=
RESEND_API_KEY=
NOTION_TOKEN=
NOTION_DATABASE_ID=
PAGERDUTY_ROUTING_KEY=
API_HEALTH_URL=
SLACK_CHANNEL=
SLACK_ALERT_CHANNEL=
